# ========================================
# HireReady AI - Environment Variables
# ========================================

# Database Configuration (Supabase)
# Get from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-public-key-here

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://hire-ready-ai-lime.vercel.app

# OpenAI API Key (Get from: https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# Razorpay Payment Gateway (Get from: https://dashboard.razorpay.com/app/keys)
# Use test keys for development
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=rzp_test_your_key_secret

# Server Configuration
PORT=8000
HOST=0.0.0.0
